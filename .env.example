# ── Airtable ──────────────────────────────────────────────────────────────────
# Base ID (public, no risk)
NEXT_PUBLIC_AT_BASE=appdpkBZRuqEWgOwB

# Server-side token (NEVER commit a real token)
# Set this on Vercel: Settings → Environment Variables
# When set, the browser never sees this token — all Airtable calls
# go through /api/airtable (server-side proxy)
AIRTABLE_TOKEN=patXXXXXXXXX.XXXXXXXXX

# ── Optional ──────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXX
